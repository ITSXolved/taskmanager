# Supabase — copy to .env and fill with your project values (Project Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only. NEVER expose with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public app URL used in WhatsApp credential messages (the /login link).
NEXT_PUBLIC_APP_URL=http://localhost:3000
